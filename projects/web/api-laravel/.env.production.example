# Variables de producción de la API (Laravel) — configúralas en Railway/Render.

APP_NAME=TRACKLIFE
APP_ENV=production
APP_DEBUG=false
# Genera una: `php artisan key:generate --show` y pega el resultado aquí.
APP_KEY=

# MongoDB Atlas (free M0) → Connect → Drivers → copia la connection string.
# Sustituye <user>, <pass>, <cluster> y añade el nombre de BD "tracklife".
DB_CONNECTION=mongodb
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/tracklife?retryWrites=true&w=majority
MONGO_DATABASE=tracklife

# Origen(es) del front para CORS (coma-separados). Pega tu URL de Vercel:
CORS_ALLOWED_ORIGINS=https://TU-APP.vercel.app

# Defaults seguros para un free tier:
SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
LOG_CHANNEL=stderr
