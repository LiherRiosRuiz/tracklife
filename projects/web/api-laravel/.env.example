APP_NAME=TRACKLIFE
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mongodb
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_DATABASE=tracklife
MONGO_USERNAME=admin
MONGO_PASSWORD=changeme_in_production
MONGODB_URI=mongodb://admin:changeme_in_production@127.0.0.1:27017/tracklife?authSource=admin

SANCTUM_STATEFUL_DOMAINS=app.tracklife.test,tracklife.test,localhost,localhost:3000

# SESSION_DRIVER=file: `database` is broken against this app's MongoDB connection —
# Illuminate\Session\DatabaseSessionHandler inserts a plain `id` column on write,
# but mongodb/laravel-mongodb's query builder (Grammar::prepareFieldsForQuery)
# renames any top-level `id` key to `_id` on insert, so the row never actually
# gets an `id` value. The unique index on sessions.id then rejects every
# session past the first as a duplicate null (E11000 dup key: { id: null }).
# This API authenticates purely via Sanctum Bearer tokens (see bootstrap/app.php
# — no cookie/session-based auth exists), so sessions are not load-bearing here;
# `file` is used instead: proven to work, zero MongoDB coupling.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
