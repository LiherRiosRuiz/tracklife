---
import Layout from "../layouts/Layout.astro";
const appUrl = "http://app.tracklife.test";

const features = [
  { icon: "🥗", title: "Nutrición", desc: "Diario alimentario, macros en tiempo real, escáner de código de barras y recetas personalizadas." },
  { icon: "🏋️", title: "Entrenamiento", desc: "Sesiones de gym, planes personalizados, cardio y calendario semanal con seguimiento de PRs." },
  { icon: "📊", title: "Biométricos", desc: "Peso, composición corporal, frecuencia cardíaca, HRV y calidad del sueño todo en un historial." },
  { icon: "👥", title: "Comunidad", desc: "Feed social, clubs, retos activos y un sistema de rachas para no perder la motivación." },
];

const steps = [
  { num: "01", title: "Regístrate gratis", desc: "Crea tu cuenta en segundos. Sin tarjeta de crédito, sin compromisos." },
  { num: "02", title: "Define tu objetivo", desc: "Peso objetivo, porcentaje de grasa, fecha límite. El coach IA adapta el plan a ti." },
  { num: "03", title: "Registra y mide", desc: "Cada comida, cada entreno, cada métrica. Todo en un lugar, todo conectado." },
];

const stats = [
  { value: "4", label: "Módulos integrados" },
  { value: "100%", label: "Open source" },
  { value: "∞", label: "Datos sin límite" },
  { value: "0€", label: "Para empezar" },
];
---

<Layout
  title="TRACKLIFE — Tu cuerpo. Tus datos. Tu control."
  description="Plataforma integral de fitness: nutrición, entrenamiento, biométricos y comunidad. Todo conectado, todo medible, todo tuyo."
>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-24 pb-20 text-center">
    <div class="inline-flex items-center gap-2 rounded-full border border-border bg-card px-4 py-1.5 text-xs text-muted mb-8">
      <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
      Plataforma fitness open source
    </div>
    <h1 class="text-6xl md:text-8xl font-black tracking-tight leading-none mb-6">
      Tu cuerpo.<br />
      <span class="text-accent">Tus datos.</span><br />
      Tu control.
    </h1>
    <p class="text-lg md:text-xl text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
      Nutrición, entrenamiento, recuperación y comunidad en una sola plataforma.
      Todo conectado. Todo medible. Todo tuyo.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href={`${appUrl}/registro`}
         class="rounded-2xl bg-accent px-8 py-4 text-base font-bold text-black hover:bg-green-400 transition-colors shadow-lg">
        Empezar gratis →
      </a>
      <a href="/como-funciona"
         class="rounded-2xl border border-border px-8 py-4 text-base font-semibold hover:border-accent hover:text-accent transition-colors">
        Cómo funciona
      </a>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-y border-border bg-card/50 py-12">
    <div class="max-w-4xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      {stats.map((s) => (
        <div>
          <div class="text-4xl font-black text-accent">{s.value}</div>
          <div class="mt-1 text-sm text-muted">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Features -->
  <section class="max-w-5xl mx-auto px-6 py-24">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-black mb-4">Todo lo que necesitas</h2>
      <p class="text-muted max-w-xl mx-auto">Cuatro módulos diseñados para trabajar juntos y darte una visión completa de tu salud.</p>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      {features.map((f) => (
        <div class="rounded-2xl border border-border bg-card p-8 hover:border-accent/40 transition-colors group cursor-default">
          <div class="text-4xl mb-5">{f.icon}</div>
          <h3 class="text-xl font-bold mb-3 group-hover:text-accent transition-colors">{f.title}</h3>
          <p class="text-muted text-sm leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-border bg-card/30 py-24">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-black mb-4">Tres pasos para empezar</h2>
        <p class="text-muted">Sin complicaciones. En menos de 5 minutos estás midiendo.</p>
      </div>
      <div class="space-y-10">
        {steps.map((step) => (
          <div class="flex gap-8 items-start">
            <div class="shrink-0 text-5xl font-black text-border">{step.num}</div>
            <div class="pt-2">
              <h3 class="text-xl font-bold mb-2">{step.title}</h3>
              <p class="text-muted leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="max-w-3xl mx-auto px-6 py-28 text-center">
    <h2 class="text-4xl md:text-6xl font-black mb-4 leading-tight">
      Deja de adivinar.<br />
      <span class="text-accent">Empieza a medir.</span>
    </h2>
    <p class="text-muted mb-10 max-w-lg mx-auto text-lg">
      Toma el control de tu transformación con datos reales. Es gratis.
    </p>
    <a href={`${appUrl}/registro`}
       class="inline-block rounded-2xl bg-accent px-12 py-5 text-xl font-black text-black hover:bg-green-400 transition-colors shadow-xl">
      Crear cuenta gratis
    </a>
  </section>
</Layout>
