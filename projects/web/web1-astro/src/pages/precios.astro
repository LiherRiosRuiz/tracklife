---
import Layout from "../layouts/Layout.astro";
const appUrl = "http://app.tracklife.test";

const plans = [
  {
    name: "Gratis",
    price: "0€",
    period: "para siempre",
    desc: "Todo lo que necesitas para empezar tu transformación.",
    features: [
      "Diario nutricional completo",
      "Registro de entrenamientos",
      "Biométricos básicos (peso)",
      "Coach IA con insights diarios",
      "Comunidad y feed social",
      "Sin límite de datos",
    ],
    cta: "Empezar gratis",
    href: `${appUrl}/registro`,
    highlighted: false,
  },
  {
    name: "Pro",
    price: "Próximamente",
    period: "",
    desc: "Funcionalidades avanzadas para atletas y coaches.",
    features: [
      "Todo lo de Gratis",
      "Wearables (Garmin, Apple Watch)",
      "Análisis avanzado de HRV",
      "Planes de entrenamiento IA",
      "Exportación de datos (CSV/PDF)",
      "Soporte prioritario",
    ],
    cta: "Notificarme",
    href: "#",
    highlighted: true,
  },
];
---

<Layout
  title="Precios TRACKLIFE — Empieza gratis"
  description="TRACKLIFE es gratis para siempre en sus funcionalidades principales. Sin tarjeta de crédito, sin sorpresas."
>
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-8 text-center">
    <h1 class="text-4xl md:text-6xl font-black mb-4">Precios simples</h1>
    <p class="text-fg-muted text-lg">Empieza gratis. Siempre.</p>
  </section>

  <section class="max-w-3xl mx-auto px-6 py-16 grid md:grid-cols-2 gap-8">
    {plans.map((plan) => (
      <div class={`rounded-2xl border p-8 flex flex-col ${plan.highlighted ? 'border-accent bg-surface shadow-xl shadow-accent/10' : 'border-border bg-surface'}`}>
        {plan.highlighted && (
          <div class="mb-4 inline-block rounded-full bg-accent px-3 py-1 text-xs font-bold text-on-accent">Próximamente</div>
        )}
        <h2 class="text-2xl font-black mb-1">{plan.name}</h2>
        <div class="mb-1">
          <span class={`text-4xl font-black ${plan.highlighted ? 'text-fg-muted' : 'text-accent'}`}>{plan.price}</span>
          {plan.period && <span class="text-sm text-fg-muted ml-1">{plan.period}</span>}
        </div>
        <p class="text-fg-muted text-sm mb-6">{plan.desc}</p>
        <ul class="space-y-3 mb-8 flex-1">
          {plan.features.map((f) => (
            <li class="flex items-center gap-2 text-sm">
              <span class={plan.highlighted ? 'text-fg-muted' : 'text-accent'}>✓</span>
              <span>{f}</span>
            </li>
          ))}
        </ul>
        <a href={plan.href}
           class={`block rounded-xl py-3 text-center font-bold transition-colors ${plan.highlighted ? 'border border-border text-fg-muted cursor-not-allowed' : 'bg-accent text-on-accent hover:bg-accent-strong'}`}>
          {plan.cta}
        </a>
      </div>
    ))}
  </section>

  <section class="max-w-2xl mx-auto px-6 pb-20 text-center">
    <p class="text-fg-muted text-sm">
      ¿Preguntas? El proyecto es open source —
      <a href="https://github.com/LiherRiosRuiz/tracklife" class="text-accent hover:underline">revisa el código</a>.
    </p>
  </section>
</Layout>
