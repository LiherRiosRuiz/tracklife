# Variables de producción del front (Next.js) — configúralas en Vercel.
# Copia estos nombres en Vercel → Project → Settings → Environment Variables.

# URL pública de la API Laravel (Railway/Render). Se usa tanto server-side
# (Next BFF) como client-side. Mismo valor en ambas:
API_INTERNAL_URL=https://TU-API.up.railway.app
NEXT_PUBLIC_API_URL=https://TU-API.up.railway.app

# URL pública del propio front (opcional, para enlaces absolutos):
NEXT_PUBLIC_APP_URL=https://TU-APP.vercel.app

# NODE_ENV lo pone Vercel automáticamente (production) → cookie de sesión
# se sirve con Secure (HTTPS). No hace falta declararlo.
