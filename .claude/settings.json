{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "gentle-ai skill-registry refresh --quiet --no-gitignore --cwd \"${CLAUDE_PROJECT_DIR:-$PWD}\" || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "outputStyle": "Gentleman",
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(docker:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(make:*)",
      "Bash(php artisan:*)",
      "Bash(./vendor/bin/pint:*)",
      "Bash(./vendor/bin/phpunit:*)",
      "Bash(composer:*)",
      "Bash(node:*)"
    ]
  }
}
